# =============================================================================
# KU Demo Student Portal - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# For Docker Compose, the docker/.env.example provides container-specific defaults.

# ──────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────
DATABASE_URL="postgresql://kuportal:kuportal123@localhost:5432/ku_portal?schema=public"

# ──────────────────────────────────────
# Redis
# ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ──────────────────────────────────────
# JWT Authentication
# ──────────────────────────────────────
JWT_SECRET=ku-portal-jwt-secret-change-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=ku-portal-refresh-secret-change-in-production
JWT_REFRESH_EXPIRATION=7d

# ──────────────────────────────────────
# UniElection Integration
# ──────────────────────────────────────
# Set to 'mock' for local development, 'iframe' or 'sdk' for real integration
UNIELECTION_API_URL=http://localhost:4000/api
UNIELECTION_API_KEY=mock-api-key-ku-portal
UNIELECTION_VOTING_JWT_SECRET=mock-voting-jwt-secret-dev
INTEGRATION_MODE=mock

# ──────────────────────────────────────
# Application
# ──────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ──────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ──────────────────────────────────────
# Frontend
# ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME="KU Demo Portal"
